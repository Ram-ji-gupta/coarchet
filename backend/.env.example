# Server Configuration
PORT=5000

# MySQL Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3311
DB_USER=woolcraft_user
DB_PASSWORD=woolcraft_password
DB_NAME=woolcraft

# If you prefer to use root locally, replace DB_USER and DB_PASSWORD with your root credentials.
# JWT Secret Key (generate a strong secret for production)
JWT_SECRET=your_strong_jwt_secret_key_here_change_this

# Optional SQL dump import path (default: ../database/woolcraft-full.sql)
DB_INIT_SQL_PATH=../database/woolcraft-full.sql
