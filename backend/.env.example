# Server Configuration
PORT=5000

# MySQL Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3311
DB_USER=croch_etgallery_user
DB_PASSWORD=croch_etgallery_password
DB_NAME=croch_etgallery

# If you prefer to use root locally, replace DB_USER and DB_PASSWORD with your root credentials.
# JWT Secret Key (generate a strong secret for production)
JWT_SECRET=your_strong_jwt_secret_key_here_change_this

# Optional SQL dump import path (default: ../database/croch_etgallery-full.sql)
DB_INIT_SQL_PATH=../database/croch_etgallery-full.sql

